{
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 0,
    "margin-top": 4,
    "margin-left": 8,
    "margin-right": 8,
    "margin-bottom": 0,

    "modules-left": [
        "custom/aperture",
        "custom/sfu_scedule",
        "hyprland/workspaces"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "tray",
        "custom/facility-status",
        "group/hardware",
        "group/connectivity",
        "group/controls"
    ],

    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory", "temperature"]
    },

    "group/connectivity": {
        "orientation": "horizontal",
        "modules": ["pulseaudio", "backlight", "network", "bluetooth"]
    },

    "group/controls": {
        "orientation": "horizontal",
        "modules": ["battery", "custom/idle-toggle", "custom/notification", "custom/power"]
    },

    "custom/aperture": {
        "format": "ŌŚē",
        "tooltip-format": "APERTURE SCIENCE ENRICHMENT CENTER\nClick: App Launcher\nRight-click: Refresh bar",
        "on-click": "pkill rofi || true && rofi -show drun -modi drun,filebrowser,run,window",
        "on-click-right": "~/.config/hypr/scripts/Refresh.sh"
    },

    "custom/facility-status": {
        "format": "{}",
        "return-type": "json",
        "exec": "~/.config/hypr/scripts/FacilityStatus.sh",
        "interval": 5,
        "tooltip": true
    },

    "clock": {
        "format": "{:%H:%M:%S}",
        "format-alt": "{:%A  //  %d %B %Y}",
        "tooltip-format": "<big>{:%H:%M:%S  //  %Y.%m.%d}</big>\n<tt>{calendar}</tt>",
        "interval": 1,
        "on-click-right": "gnome-calendar || true"
    },

    "custom/sfu_scedule": {
        "format": "¾░łÖ",
        "tooltip": false,
        "on-click": "/home/cytr/.config/sfu-schedule/target/release/sfu-schedule"
    },

    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{icon} {windows}",
        "format-window-separator": " ",
        "window-rewrite-default": "’ŗÉ",
        "window-rewrite": {
            "class<kitty>": "’Æē",
            "class<firefox>": "’ē®",
            "class<obsidian>": "¾░Ā«",
            "class<org.kde.kate>": "¾░łÖ",
            "class<thunar>": "¾░ēō",
            "class<org.ime.desktop.*>": "¾░Ł╣",
            "class<code>": "¾░©×",
            "class<cursor>": "¾░©×",
            "class<virt-manager>": "¾░ó╣",
            "class<steam>": "¾░ōō"
        },
        "format-icons": {
            "1": "01", "2": "02", "3": "03",
            "4": "04", "5": "05", "6": "06",
            "7": "07", "8": "08", "9": "09",
            "active": "ŌŚÅ",
            "default": "ŌŚŗ",
            "urgent": "!"
        },
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "sort-by-number": true,
        "persistent-workspaces": {
            "1": [], "2": [], "3": [],
            "4": [], "5": [], "6": []
        }
    },

    "cpu": {
        "format": " {usage}%",
        "interval": 2,
        "tooltip-format": "CPU: {usage}%\nFreq: {avg_frequency} GHz\n{load} load",
        "on-click": "kitty -e htop",
        "states": {
            "normal": 0,
            "warning": 70,
            "critical": 90
        }
    },

    "memory": {
        "format": " {percentage}%",
        "interval": 2,
        "tooltip-format": "RAM: {used:0.1f} GiB / {total:0.1f} GiB ({percentage}%)\nSwap: {swapUsed:0.1f} GiB / {swapTotal:0.1f} GiB",
        "on-click": "kitty -e htop",
        "states": {
            "normal": 0,
            "warning": 75,
            "critical": 90
        }
    },

    "temperature": {
        "format": " {temperatureC}┬░",
        "critical-threshold": 80,
        "format-critical": " {temperatureC}┬░",
        "tooltip-format": "CPU Temperature: {temperatureC}┬░C / {temperatureF}┬░F",
        "interval": 5
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "¾░¢ü MUTE",
        "format-icons": {
            "default": ["¾░Ģ┐", "¾░¢Ć", "¾░ĢŠ"]
        },
        "scroll-step": 5,
        "on-click": "pavucontrol",
        "on-click-right": "pamixer -t",
        "on-scroll-up": "~/.config/hypr/scripts/Volume.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/Volume.sh --dec",
        "tooltip-format": "Volume: {volume}%\nOutput: {desc}"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["¾░ā×", "¾░ā¤", "¾░āĀ"],
        "scroll-step": 5,
        "tooltip-format": "Brightness: {percent}%",
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    "network": {
        "format-wifi": "¾░¢® {signalStrength}%",
        "format-ethernet": "¾░łĆ",
        "format-disconnected": "¾░¢¬",
        "tooltip-format-wifi": "NETWORK: {essid}\nSignal: {signalStrength}%\nIP: {ipaddr}/{cidr}\nUp: {bandwidthUpBytes} Down: {bandwidthDownBytes}",
        "tooltip-format-ethernet": "{ifname}\nIP: {ipaddr}/{cidr}\nUp: {bandwidthUpBytes} Down: {bandwidthDownBytes}",
        "tooltip-format-disconnected": "NETWORK: OFFLINE",
        "interval": 2,
        "on-click": "nm-connection-editor",
        "ignore": ["tun*", "docker*", "br-*", "lo", "virbr*", "tailscale*", "wg*", "veth*"]
    },

    "bluetooth": {
        "format": "¾░é»",
        "format-disabled": "¾░é▓",
        "format-connected": "¾░é▒ {num_connections}",
        "tooltip-format": "Bluetooth: {status}\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "  {device_alias}",
        "tooltip-format-enumerate-connected-battery": "  {device_alias} ({device_battery_percentage}%)",
        "on-click": "blueman-manager"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"],
        "format-charging": "¾░éä {capacity}%",
        "format-plugged": "¾░Üź {capacity}%",
        "format-full": "¾░éģ",
        "tooltip-format": "Battery: {capacity}%\n{timeTo}\nPower: {power:.1f}W",
        "states": {
            "good": 80,
            "warning": 35,
            "critical": 15
        }
    },

    "tray": {
        "spacing": 8,
        "icon-size": 15
    },

    "custom/idle-toggle": {
        "format": "{}",
        "exec": "if pgrep -x hypridle > /dev/null; then echo '¾░Æ▓'; else echo '¾░Æ│'; fi",
        "interval": 5,
        "on-click": "$HOME/.config/hypr/scripts/IdleToggle.sh",
        "tooltip-format": "Toggle idle tracking"
    },

    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "¾▒ģ½",
            "none": "",
            "dnd-notification": " ",
            "dnd-none": "¾░éø",
            "inhibited-notification": " ",
            "inhibited-none": "",
            "dnd-inhibited-notification": " ",
            "dnd-inhibited-none": " "
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "sleep 0.1 && swaync-client -t -sw",
        "on-click-right": "sleep 0.1 && swaync-client -d -sw",
        "escape": true
    },

    "custom/power": {
        "format": "¾░Éź",
        "on-click": "wlogout --protocol layer-shell",
        "tooltip-format": "FACILITY SHUTDOWN PROTOCOL"
    }
}
